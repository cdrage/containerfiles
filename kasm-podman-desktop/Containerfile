#**Description:**
#
# Using KASM (basically web-based VNC) to test Podman Desktop pull requests.
#
# On startup, pass a PR number via the PR_NUMBER environment variable.
# The container will fetch the PR, install dependencies, compile and launch
# Podman Desktop so you can test it in your browser.
#
# **IMPORTANT:**
#
# There is **NO AUTHENTICATION** and **NO SSL** in this container. This is meant for local use only, or when you have a reverse proxy in front of it.
# In my use-case, I am using nginx with Let's Encrypt and basic auth, so I do not need the VNC server to have its own authentication.
#
# **Running:**
#
# ```sh
# podman run -it --rm \
#  --device /dev/fuse \
#  --security-opt label=disable \
#  --security-opt unmask=ALL \
#  -e PR_NUMBER=12345 \
#  -e PODMAN_VERSION=v5.4.2 \
#  -p 6901:6901 \
#  --shm-size=2g \
#  ghcr.io/cdrage/kasm-podman-desktop:latest
# ```
#
# --device /dev/fuse, --security-opt label=disable, and --security-opt unmask=ALL
# are required for rootless Podman inside the container (see https://www.redhat.com/en/blog/podman-inside-container).
# PR_NUMBER is optional. If not set, uses latest main.
# PODMAN_VERSION is optional. If set, downloads a static build from
# https://github.com/podman-container-tools/podman/releases
# If not set, uses Fedora's default Podman.
# NPM_CONFIG_REGISTRY is optional. If set, pnpm fetches packages from this
# registry (e.g. a Verdaccio instance) instead of the public npm registry.
# DEV_MODE is optional. If set to "true", uses `pnpm watch` instead of
# `pnpm build` + `electron`. This enables Vite's dev server with HMR
# so UI changes are reflected instantly without a full rebuild.

FROM kasmweb/core-fedora-43:develop

#! Initial setup
USER root
ENV HOME /home/kasm-default-profile
ENV STARTUPDIR /dockerstartup
ENV INST_SCRIPTS $STARTUPDIR/install
WORKDIR $HOME

#! ===== Podman-in-Podman setup =====
#! Running rootless Podman inside a container requires several workarounds.
#! Reference: https://www.redhat.com/en/blog/podman-inside-container
#!
#! At runtime, the container must be launched with:
#!   --device /dev/fuse --security-opt label=disable
#! or --privileged (for Kubernetes).
#!
#! 1. Install Podman and rootless dependencies
#!    - fuse-overlayfs: storage driver for nested containers (native overlay-on-overlay doesn't work)
#!    - slirp4netns: rootless networking backend (pasta's close_range() syscall is blocked by seccomp)
RUN dnf install -y \
        podman \
        fuse-overlayfs \
        slirp4netns \
        wmctrl \
        scrot \
        firefox \
        xdg-utils && \
    dnf clean all

RUN xdg-settings set default-web-browser firefox.desktop 2>/dev/null || true && \
    mkdir -p $HOME/.local/share/applications && \
    xdg-mime default firefox.desktop x-scheme-handler/http 2>/dev/null || true && \
    xdg-mime default firefox.desktop x-scheme-handler/https 2>/dev/null || true

#! 1b. Replace pkexec with a sudo wrapper
#!     Podman Desktop extensions (kind, kubectl-cli, compose) use pkexec
#!     to install binaries into /usr/local/bin. Real pkexec crashes in
#!     containers due to a polkit assertion on process start time
#!     (polkit_unix_process_get_start_time). Since kasm-user has NOPASSWD
#!     sudo, we shim pkexec to delegate to sudo instead.
RUN mv /usr/bin/pkexec /usr/bin/pkexec.real && \
    printf '#!/bin/sh\nexec sudo "$@"\n' > /usr/bin/pkexec && \
    chmod +x /usr/bin/pkexec

#! 2. Setup subuid/subgid ranges for rootless user namespace mapping
#!    chmod u+s on newuidmap/newgidmap: these need the setuid bit to map
#!    user namespaces inside a container (otherwise: "Operation not permitted")
RUN echo "kasm-user:100000:65536" >> /etc/subuid && \
    echo "kasm-user:100000:65536" >> /etc/subgid && \
    chmod u+s /usr/sbin/newuidmap /usr/sbin/newgidmap && \
    mkdir -p /run/user/1000 && \
    chown 1000:1000 /run/user/1000

#! 3. Configure storage and networking for nested operation
#!    - storage.conf: use fuse-overlayfs as the mount program
#!    - containers.conf: use slirp4netns instead of pasta for networking
RUN mkdir -p /etc/containers $HOME/.config/containers && \
    printf '[storage]\ndriver = "overlay"\n\n[storage.options.overlay]\nmount_program = "/usr/bin/fuse-overlayfs"\nmountopt = "nodev,fsync=0"\n' > /etc/containers/storage.conf && \
    cp /etc/containers/storage.conf $HOME/.config/containers/storage.conf && \
    printf '[containers]\nlog_driver = "journald"\n\n[engine]\nevents_logger = "journald"\n\n[network]\ndefault_rootless_network_cmd = "slirp4netns"\n' > /etc/containers/containers.conf

#! 4. XDG_RUNTIME_DIR is required for the rootless Podman socket
ENV XDG_RUNTIME_DIR=/run/user/1000

#! Install Node.js 24 and build dependencies for Electron native modules
RUN curl -fsSL https://rpm.nodesource.com/setup_24.x | bash - && \
    dnf install -y \
        nodejs \
        gcc-c++ \
        make \
        python3 \
        pkgconf-pkg-config \
        libsecret-devel \
        nss \
        at-spi2-atk \
        alsa-lib \
        mesa-libgbm && \
    npm install -g pnpm@10 && \
    dnf clean all

#! Skip Playwright browser downloads (not needed for UI testing, saves ~500MB)
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1

#! Make pnpm non-interactive (no prompts about reinstalling modules)
ENV CI=true

#! Electron needs no-sandbox in containers
ENV ELECTRON_DISABLE_SANDBOX=1

#! Default VNC resolution before a browser client connects
ENV VNC_RESOLUTION=1920x1080

#! Disable audio streaming (PulseAudio + ffmpeg + websocket)
ENV KASM_SVC_AUDIO=0

#! Cache Electron binary outside $HOME so it survives the Kasm profile copy
ENV ELECTRON_CACHE=/opt/electron-cache

#! pnpm 10 "managed install" stores its tools under $PNPM_HOME/.tools/;
#! keep it outside $HOME so it survives the Kasm profile copy
ENV PNPM_HOME=/opt/pnpm-home

#! Optional: pass --build-arg NPM_REGISTRY=http://verdaccio:4873/ to use a
#! local npm cache during image build. Only affects build-time installs.
ARG NPM_REGISTRY=""

#! Clone podman-desktop and pre-install dependencies on main branch to speed up PR checkout
#! Use an explicit pnpm store outside $HOME so it survives the Kasm profile copy
RUN git clone --single-branch --branch main --depth 1 https://github.com/podman-desktop/podman-desktop.git /opt/podman-desktop && \
    cd /opt/podman-desktop && \
    pnpm config set store-dir /opt/pnpm-store && \
    sed -i 's/ && playwright install chromium//' package.json && \
#! --ignore-scripts: postinstall scripts segfault under QEMU when cross-building amd64 on ARM.
#! Scripts run at container startup on native x86 instead.
    if [ -n "$NPM_REGISTRY" ]; then NPM_CONFIG_REGISTRY="$NPM_REGISTRY" pnpm install --ignore-scripts; \
    else pnpm install --ignore-scripts; fi && \
    mkdir -p /opt/electron-cache && \
    node node_modules/electron/install.js && \
    chown -R 1000:0 /opt/podman-desktop /opt/pnpm-store /opt/electron-cache /opt/pnpm-home

#! Workspace for extension builds (populated at runtime by entrypoint.sh)
RUN mkdir -p /opt/extension-src && chown 1000:0 /opt/extension-src

#! Add to sudo users and systemd-journal group (needed for podman events/logging)
RUN echo 'kasm-user ALL=(ALL) NOPASSWD: ALL' >> /etc/sudoers && \
    usermod -aG systemd-journal kasm-user

#! Skip Podman Desktop welcome/onboarding screen and create managed config directory
RUN mkdir -p $HOME/.local/share/containers/podman-desktop/configuration && \
    echo '{ "welcome.version": "initial" }' > $HOME/.local/share/containers/podman-desktop/configuration/settings.json && \
    mkdir -p /usr/share/podman-desktop

#! Pre-select Console tab in Developer Tools (dev mode)
RUN mkdir -p "$HOME/.config/Podman Desktop" && \
    echo '{"electron":{"devtools":{"preferences":{"panel-selected-tab":"\"console\"","currentDockState":"\"undocked\""}}}}' > "$HOME/.config/Podman Desktop/Preferences"

#! Desktop shortcuts
RUN mkdir -p $HOME/Desktop && \
    printf '[Desktop Entry]\nType=Application\nName=Podman Desktop\nExec=sh -c "cd /opt/podman-desktop && npx electron . --no-sandbox"\nIcon=utilities-terminal\nTerminal=false\nCategories=Development;\n' > $HOME/Desktop/podman-desktop.desktop && \
    printf '[Desktop Entry]\nType=Application\nName=Terminal\nExec=xfce4-terminal\nIcon=utilities-terminal\nTerminal=false\nCategories=System;\n' > $HOME/Desktop/terminal.desktop && \
    printf '[Desktop Entry]\nType=Application\nName=Managed Config\nExec=xfce4-terminal --working-directory=/usr/share/podman-desktop\nIcon=folder\nTerminal=false\nCategories=System;\n' > $HOME/Desktop/managed-config.desktop && \
    printf '[Desktop Entry]\nType=Application\nName=Firefox\nExec=firefox --no-remote\nIcon=firefox\nTerminal=false\nCategories=Network;WebBrowser;\n' > $HOME/Desktop/firefox.desktop && \
    chmod +x $HOME/Desktop/*.desktop

#! Desktop wallpaper
COPY wallpaper.png /usr/share/backgrounds/wallpaper.png
RUN mkdir -p $HOME/.config/xfce4/xfconf/xfce-perchannel-xml && \
    printf '<?xml version="1.0" encoding="UTF-8"?>\n<channel name="xfce4-desktop" version="1.0">\n  <property name="backdrop" type="empty">\n    <property name="screen0" type="empty">\n      <property name="monitorVNC-0" type="empty">\n        <property name="workspace0" type="empty">\n          <property name="last-image" type="string" value="/usr/share/backgrounds/wallpaper.png"/>\n          <property name="image-style" type="int" value="5"/>\n        </property>\n      </property>\n      <property name="monitornone" type="empty">\n        <property name="workspace0" type="empty">\n          <property name="last-image" type="string" value="/usr/share/backgrounds/wallpaper.png"/>\n          <property name="image-style" type="int" value="5"/>\n        </property>\n      </property>\n    </property>\n  </property>\n</channel>\n' > $HOME/.config/xfce4/xfconf/xfce-perchannel-xml/xfce4-desktop.xml

#! Silence pcscd spam from vnc_startup.sh (smartcard daemon not needed)
#! Kasm monitors pcscd and restarts it if it exits, so we need a stub that stays alive
RUN printf '#!/bin/sh\nexec sleep infinity\n' > /usr/local/sbin/pcscd && chmod +x /usr/local/sbin/pcscd


COPY custom_startup.sh $STARTUPDIR/custom_startup.sh
RUN chmod +x $STARTUPDIR/custom_startup.sh

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

#! For deploying on Kubernetes, we disable SSL by default so that we can access it via HTTP (reverse proxy + let's encrypt
#! We do this by changing required_ssl in /usr/share/kasmvnc/kasmvnc_defaults.yaml from required_ssl: true to required_ssl: false
RUN sed -i -E 's/^([[:space:]]*)require_ssl:[[:space:]]*true/\1require_ssl: false/' /usr/share/kasmvnc/kasmvnc_defaults.yaml
RUN cat /usr/share/kasmvnc/kasmvnc_defaults.yaml

#! Remove "-sslOnly" from the VNC startup script and replace it with "-disableBasicAuth"
#! WARNING: This is DANGEROUS and NOT SECURE. The ONLY reason why I am doing this, is that I am using nginx reverse proxy + let's encrypt + basic auth
#! already, so I do not need the VNC server to have its own authentication + SSL.
RUN sed -i.bak 's/-sslOnly/-disableBasicAuth/' /dockerstartup/vnc_startup.sh

#! Default user
RUN chown 1000:0 $HOME
RUN $STARTUPDIR/set_user_permission.sh $HOME

ENV HOME /home/kasm-user
WORKDIR $HOME
RUN mkdir -p $HOME && chown -R 1000:0 $HOME

#! Inner Podman storage must live on a non-overlay filesystem to avoid
#! overlay-on-overlay failures. VOLUME creates an automatic anonymous volume
#! for podman/docker run; for Kubernetes, an emptyDir is mounted at this path.
VOLUME /home/kasm-user/.local/share/containers

USER 1000

ENTRYPOINT ["/entrypoint.sh"]
CMD ["--wait"]
